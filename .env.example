NEXT_PUBLIC_DEMO_MODE=true

# Live answer-engine providers
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Product-page context extraction
FIRECRAWL_API_KEY=

# Notes:
# - NEXT_PUBLIC_DEMO_MODE=true forces seeded mock mode.
# - NEXT_PUBLIC_DEMO_MODE=false enables live provider mode when one or more provider keys exist.
# - Gemini + Firecrawl are enough for the main live demo API/tool path.
# - OpenAI and Anthropic are optional live adapters and are enabled automatically when keys are present.
# - Never prefix secret provider keys with NEXT_PUBLIC_.
