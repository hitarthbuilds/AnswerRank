NEXT_PUBLIC_DEMO_MODE=true
ANSWER_RANK_FULL_AUDIT_ENABLED=false
ANSWER_RANK_LLM_QUERY_EXPANSION=false

# Live answer-engine providers
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Product-page context extraction
FIRECRAWL_API_KEY=

# Optional Redis for production-safe rate limiting and caching
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Notes:
# - NEXT_PUBLIC_DEMO_MODE=true forces seeded mock mode.
# - NEXT_PUBLIC_DEMO_MODE=false enables live provider mode when one or more provider keys exist.
# - Gemini + Firecrawl are enough for the main live demo API/tool path.
# - OpenAI and Anthropic are optional live adapters and are enabled automatically when keys are present.
# - ANSWER_RANK_FULL_AUDIT_ENABLED=true unlocks the full audit mode when the frontend requests it.
# - ANSWER_RANK_LLM_QUERY_EXPANSION=true allows optional Gemini-assisted query expansion for full audits.
# - Upstash Redis is recommended for production rate limiting and report caching.
# - Never prefix secret provider keys with NEXT_PUBLIC_.
